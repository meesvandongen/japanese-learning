# Serve kuromoji dict files as raw binary — do NOT let Cloudflare decompress
# them. kuromoji's BrowserDictionaryLoader decompresses the gzip bytes itself.
/dict/*.dat.gz
  Content-Type: application/octet-stream
  Content-Encoding: identity
  Cache-Control: public, max-age=31536000, immutable

# Vocabulary manifest — short TTL so new languages/levels propagate quickly.
# The file is tiny (~1KB) so re-fetching is cheap.
/vocab/manifest.json
  Content-Type: application/json
  Cache-Control: public, max-age=300

# Vocabulary level files — long TTL; cache-busted via ?v=N query param from
# the manifest version field whenever content changes.
/vocab/*/*.json
  Content-Type: application/json
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
