{
  "name": "@japanese-learning/web",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "postinstall": "mkdir -p public/dict && cp ../../node_modules/kuromoji/dict/*.dat.gz public/dict/",
    "prebuild": "node ../../scripts/generate-vocab.mjs",
    "dev": "node ../../scripts/generate-vocab.mjs && vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@japanese-learning/core": "*",
    "@patdx/kuromoji": "^1.0.0",
    "@sqlite.org/sqlite-wasm": "^3.46.0-build2",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tanstack/react-query": "^5.95.2",
    "@tanstack/react-router": "^1.168.10",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-native": "0.85.2",
    "react-native-web": "~0.21.2",
    "tamagui": "^2.0.0-rc.41",
    "wanakana": "^5.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@playwright/test": "^1.50.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "kuromoji": "^0.1.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
