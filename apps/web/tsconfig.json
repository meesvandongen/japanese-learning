{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "paths": {
      "@japanese-learning/core": ["../../packages/core/src/index.ts"],
      "@japanese-learning/core/*": ["../../packages/core/src/*"]
    }
  },
  "include": ["src", "../../packages/core/src"],
  "exclude": [
    "node_modules",
    "../../packages/core/src/**/*.native.ts",
    "../../packages/core/src/**/*.test.ts"
  ]
}
