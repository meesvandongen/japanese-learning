{
  "name": "@japanese-learning/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "private": true,
  "scripts": {
    "postinstall": "mkdir -p public/dict assets/dict && cp ../../node_modules/kuromoji/dict/*.dat.gz public/dict/ && cp ../../node_modules/kuromoji/dict/*.dat.gz assets/dict/",
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "prebuild": "expo prebuild",
    "build:web": "node ../../scripts/generate-vocab-db.mjs && expo export --platform web --output-dir dist",
    "preview:web": "npm run build:web && wrangler dev",
    "deploy": "npm run build:web && wrangler deploy",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "generate-vocab": "node ../../scripts/generate-vocab-db.mjs"
  },
  "dependencies": {
    "@japanese-learning/core": "*",
    "@patdx/kuromoji": "^1.0.4",
    "@sqlite.org/sqlite-wasm": "^3.53.0-build1",
    "@tamagui/config": "^2.0.0-rc.41",
    "@tamagui/lucide-icons": "^2.0.0-rc.26",
    "@tanstack/react-query": "^5.95.2",
    "expo": "^55.0.0",
    "expo-asset": "~55.0.16",
    "expo-audio": "~55.0.14",
    "expo-constants": "~55.0.15",
    "expo-file-system": "~55.0.17",
    "expo-font": "~14.0.0",
    "expo-keep-awake": "~55.0.6",
    "expo-linking": "~55.0.14",
    "expo-router": "~55.0.13",
    "expo-speech": "~55.0.13",
    "expo-speech-recognition": "^3.1.2",
    "expo-splash-screen": "~55.0.19",
    "expo-sqlite": "~55.0.15",
    "expo-status-bar": "~55.0.5",
    "expo-updates": "~55.0.0",
    "react-native-track-player": "^4.1.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-native": "0.85.2",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-mmkv": "^4.3.1",
    "react-native-reanimated": "~4.3.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.24.0",
    "react-native-web": "~0.21.2",
    "tamagui": "^2.0.0-rc.41",
    "wanakana": "^5.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@playwright/test": "^1.50.1",
    "@tamagui/babel-plugin": "^2.0.0-rc.41",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~55.0.18",
    "typescript": "^6.0.2",
    "wrangler": "^4.78.0"
  }
}
