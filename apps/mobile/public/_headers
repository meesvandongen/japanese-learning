# Cross-Origin headers required by OPFS / SharedArrayBuffer — sqlite-wasm's
# OPFS VFS won't activate without these. Without OPFS we can't persist the
# vocab database in the browser, so the app degrades to "fetch every time".
/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp

# Serve kuromoji dict files as raw binary — do NOT let Cloudflare decompress
# them. kuromoji's BrowserDictionaryLoader decompresses the gzip bytes itself.
/dict/*.dat.gz
  Content-Type: application/octet-stream
  Content-Encoding: identity
  Cache-Control: public, max-age=31536000, immutable

# Vocabulary database — long TTL; cache-busted via the manifest_version
# stored inside the .db file (bumped in scripts/generate-vocab-db.mjs).
/vocab.db
  Content-Type: application/vnd.sqlite3
  Cache-Control: public, max-age=86400, stale-while-revalidate=604800
