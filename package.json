{
  "name": "japanese-learning",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "mkdir -p public/dict && cp node_modules/kuromoji/dict/*.dat.gz public/dict/ && cp node_modules/kuromoji/build/kuromoji.js public/kuromoji.js",
    "vocab:generate": "node scripts/generate-vocab.mjs",
    "prebuild": "node scripts/generate-vocab.mjs",
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "lint": "oxlint --config oxlint.json src/",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:unit": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wanakana": "^5.3.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@playwright/test": "^1.50.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "kuromoji": "^0.1.2",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "wrangler": "^4.78.0"
  }
}
