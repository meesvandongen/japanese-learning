{
  "name": "japanese-learning",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "postinstall": "mkdir -p public/dict && cp node_modules/kuromoji/dict/*.dat.gz public/dict/ && cp node_modules/kuromoji/build/kuromoji.js public/kuromoji.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "test": "playwright test",
    "test:ui": "playwright test --ui"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.95.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "wanakana": "^5.3.1"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.30.2",
    "@playwright/test": "^1.50.1",
    "@vitejs/plugin-react": "^6.0.1",
    "kuromoji": "^0.1.2",
    "vite": "^8.0.3",
    "wrangler": "^4.78.0"
  }
}
