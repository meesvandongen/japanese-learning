{
  "name": "japanese-learning",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "vocab:generate": "node scripts/generate-vocab-db.mjs",
    "dev": "npm run start --workspace apps/mobile",
    "dev:web": "npm run web --workspace apps/mobile",
    "dev:ios": "npm run ios --workspace apps/mobile",
    "dev:android": "npm run android --workspace apps/mobile",
    "build:web": "npm run build:web --workspace apps/mobile",
    "preview:web": "npm run preview:web --workspace apps/mobile",
    "deploy": "npm run deploy --workspace apps/mobile",
    "lint": "oxlint --config oxlint.json apps packages",
    "test:e2e": "npm run test:e2e --workspace apps/mobile",
    "test:unit": "npm run test:unit --workspace packages/core --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "better-sqlite3": "^11.5.0",
    "kuromoji": "^0.1.2",
    "oxlint": "^1.58.0",
    "typescript": "^6.0.2"
  }
}
